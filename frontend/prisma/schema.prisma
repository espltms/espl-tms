datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  SUPER_ADMIN
  REGION_ADMIN
  VENDOR
  SYS_ADMIN
  LOGISTICS_MANAGER
  DISPATCHER
  COMPLIANCE_OFFICER
  FINANCE_OFFICER
  GATE_OPERATOR
  DRIVER_PARTNER
  PARAMANANDPUR_ADMIN
  DHARAMGARH_ADMIN
  BHAWANIPATNA_ADMIN
  LANJIGARH_LOADER
  PARAMANANDPUR_UNLOADER
  DHARAMGARH_UNLOADER
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  SUSPENDED
  INACTIVE
}

enum TruckStatus {
  SCHEDULED
  IN_TRANSIT
  RECEIVED
  ACTION
  COMPLETED
  AVAILABLE
  ON_TRIP
  MAINTENANCE
  OUT_OF_SERVICE
}

enum FleetCategory {
  OWNED_FLEET
  ATTACHED_FLEET
}

enum TripStatus {
  IN_TRANSIT
  RECEIVED
  ACTION
  SCHEDULED
  GATE_IN_LOADING
  LOADING
  DISPATCHED
  GATE_OUT_LOADING
  EN_ROUTE
  GATE_IN_UNLOADING
  UNLOADING
  GATE_OUT_UNLOADING
  COMPLETED
  CANCELLED
}

enum POStatus {
  DRAFT
  ACTIVE
  EXHAUSTED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PENDING_RECONCILIATION
  PAID
  OVERDUE
  DISPUTED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  fullName     String
  role         String    @default("SYS_ADMIN")
  phone        String?
  regionName   String?
  vendorName   String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  syncedRecords SyncedRecord[]

  @@index([email])
}

model CustomRole {
  id        String   @id @default(uuid())
  name      String   @unique
  routes    Json     // stores array of allowed routes (e.g., ["/trips", "/unloading"])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SyncedRecord {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordType String
  recordKey  String
  payload    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, recordType, recordKey])
  @@index([userId, recordType])
  @@index([recordKey])
}

model Driver {
  id                 String       @id @default(uuid())
  fullName           String
  licenseNumber      String       @unique
  licenseExpiry      DateTime     @default(now())
  status             DriverStatus @default(AVAILABLE)
  phone              String       @unique
  complianceVerified Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  trips Trip[]

  @@index([licenseNumber])
  @@index([status, createdAt])
  @@index([complianceVerified])
}

model Truck {
  id                 String      @id @default(uuid())
  plateNumber        String      @unique
  model              String
  capacityTons       Decimal     @db.Decimal(10, 2)
  type               String
  fleetCategory      FleetCategory @default(OWNED_FLEET)
  fuelCard           String?
  health             Int         @default(100)
  status             TruckStatus @default(AVAILABLE)
  complianceVerified Boolean     @default(false)

  // Fleet Master Details
  vendor             String?
  subVendor          String?
  wheeler            String?
  rcNo               String?
  fitnessValidityFrom String?
  fitnessValidityTo   String?
  insuranceValidityUpto String?
  pucValidity         String?
  driverName         String?
  driverDL           String?
  dlValidityTill     String?
  driverMobile       String?

  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  trips Trip[]

  @@index([plateNumber])
  @@index([fleetCategory])
  @@index([status, createdAt])
  @@index([complianceVerified])
}

model PurchaseOrder {
  id                    String   @id @default(uuid())
  poNumber              String   @unique
  clientName            String
  commodity             String
  totalQuantityTons     Decimal  @db.Decimal(12, 2)
  allocatedQuantityTons Decimal  @db.Decimal(12, 2) @default(0.00)
  ratePerTon            Decimal  @db.Decimal(10, 2)
  status                POStatus @default(ACTIVE)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  trips Trip[]

  @@index([poNumber])
  @@index([status, createdAt])
  @@index([clientName])
}

model Trip {
  id                    String     @id @default(uuid())
  tripNumber            String     @unique
  purchaseOrderId       String
  purchaseOrder         PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  driverId              String
  driver                Driver     @relation(fields: [driverId], references: [id])
  truckId               String
  truck                 Truck      @relation(fields: [truckId], references: [id])
  source                String
  destination           String
  distanceKm            Decimal    @db.Decimal(10, 2)
  estimatedQuantityTons Decimal    @db.Decimal(10, 2)
  actualLoadedTons      Decimal?   @db.Decimal(10, 2)
  actualDeliveredTons   Decimal?   @db.Decimal(10, 2)
  vendorName            String?
  vehicleType           String?
  status                TripStatus @default(SCHEDULED)
  scheduledStartDate    DateTime
  actualStartDate       DateTime?
  actualEndDate         DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  weighTickets WeighTicket[]
  invoices     Invoice[]

  @@index([tripNumber])
  @@index([status])
  @@index([status, createdAt])
  @@index([scheduledStartDate])
  @@index([purchaseOrderId])
  @@index([driverId])
  @@index([truckId])
}

model WeighTicket {
  id         String   @id @default(uuid())
  ticketNo   String   @unique
  tripId     String
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  truckPlate String
  material   String
  grossTons  Decimal  @db.Decimal(10, 2)
  tareTons   Decimal  @db.Decimal(10, 2)
  netTons    Decimal  @db.Decimal(10, 2)
  sealNumber String?
  status     String   @default("PENDING_GROSS")
  timestamp  DateTime @default(now())

  @@index([tripId])
  @@index([status, timestamp])
  @@index([truckPlate])
  @@index([timestamp])
}

model Invoice {
  id                String        @id @default(uuid())
  invoiceNumber     String        @unique
  tripId            String
  trip              Trip          @relation(fields: [tripId], references: [id])
  type              String        @default("CLIENT_INVOICE")
  subtotal          Decimal       @db.Decimal(12, 2)
  taxAmount         Decimal       @db.Decimal(12, 2)
  totalAmount       Decimal       @db.Decimal(12, 2)
  status            InvoiceStatus @default(DRAFT)
  dueDate           DateTime
  vendorName        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([invoiceNumber])
  @@index([status])
  @@index([status, createdAt])
  @@index([tripId])
  @@index([dueDate])
}

model CoalDOMaster {
  id           String    @id @default(uuid())
  doNo         String    @unique
  poNo         String
  siding       String
  mines        String?
  coalCompany  String?
  doQty        Decimal   @db.Decimal(12, 2)
  coalType     String
  startDate    String?
  endDate      String?
  status       String    @default("Active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model CoalRREntry {
  id            String    @id @default(uuid())
  doNo          String
  siding        String
  rrNo          String    @unique
  rrDate        String?
  loadingDate   String?
  receiptDate   String?
  rrActQty      Decimal   @db.Decimal(12, 2)
  rrChQty       Decimal   @db.Decimal(12, 2)
  vllQty        Decimal   @db.Decimal(12, 2)
  grnQty        Decimal   @db.Decimal(12, 2)
  normalisedQty Decimal   @db.Decimal(12, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CoalQualityTracking {
  id             String    @id @default(uuid())
  doNo           String
  rrNo           String    @unique
  tm             Decimal   @db.Decimal(12, 2)
  im             Decimal   @db.Decimal(12, 2)
  ash            Decimal   @db.Decimal(12, 2)
  vm             Decimal   @db.Decimal(12, 2)
  fc             Decimal   @db.Decimal(12, 2)
  gcvAdb         Decimal   @db.Decimal(12, 2)
  gcvArb         Decimal   @db.Decimal(12, 2)
  qualityPenalty Decimal   @db.Decimal(12, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model CoalDeductionPenalty {
  id              String    @id @default(uuid())
  doNo            String
  rrNo            String    @unique
  deadFreight     Decimal   @db.Decimal(12, 2)
  punitive        Decimal   @db.Decimal(12, 2)
  dc              Decimal   @db.Decimal(12, 2)
  shortage        Decimal   @db.Decimal(12, 2)
  qualitySlippage Decimal   @db.Decimal(12, 2)
  railwayLeakage  Decimal   @db.Decimal(12, 2)
  finalDeduction  Decimal   @db.Decimal(12, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model CoalBillingPayment {
  id           String    @id @default(uuid())
  doNo         String
  billNo       String    @unique
  billDate     String?
  billQty      Decimal   @db.Decimal(12, 2)
  billAmount   Decimal   @db.Decimal(12, 2)
  tds          Decimal   @db.Decimal(12, 2)
  advancePaid  Decimal   @db.Decimal(12, 2)
  finalPayable Decimal   @db.Decimal(12, 2)
  remarks      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
