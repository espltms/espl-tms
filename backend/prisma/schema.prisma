datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  SYS_ADMIN
  LOGISTICS_MANAGER
  DISPATCHER
  COMPLIANCE_OFFICER
  FINANCE_OFFICER
  GATE_OPERATOR
  DRIVER_PARTNER
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  SUSPENDED
  INACTIVE
}

enum TruckStatus {
  AVAILABLE
  ON_TRIP
  MAINTENANCE
  OUT_OF_SERVICE
}

enum DocumentType {
  DRIVING_LICENSE
  MEDICAL_CERTIFICATE
  VEHICLE_REGISTRATION
  VEHICLE_INSURANCE
  FITNESS_CERTIFICATE
  POLLUTION_UNDER_CONTROL
  NATIONAL_PERMIT
}

enum ComplianceStatus {
  PENDING
  APPROVED
  EXPIRED
  REJECTED
}

enum POStatus {
  DRAFT
  ACTIVE
  EXHAUSTED
  COMPLETED
  CANCELLED
}

enum TripStatus {
  SCHEDULED
  GATE_IN_LOADING
  LOADING
  DISPATCHED
  GATE_OUT_LOADING
  EN_ROUTE
  GATE_IN_UNLOADING
  UNLOADING
  GATE_OUT_UNLOADING
  COMPLETED
  CANCELLED
}

enum GatepassType {
  INBOUND
  OUTBOUND
}

enum GatepassStatus {
  ISSUED
  EXPIRED
  VOID
  USED
}

enum ExpenseCategory {
  FUEL
  TOLL
  DRIVER_ALLOWANCE
  MAINTENANCE
  REPAIR
  FINES
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
}

enum InvoiceType {
  CLIENT_INVOICE
  VENDOR_INVOICE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PENDING_RECONCILIATION
  PAID
  OVERDUE
  DISPUTED
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  fullName     String
  role         UserRole    @default(DISPATCHER)
  phone        String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  // Auditing
  auditLogs    AuditLog[]
  complianceApproved ComplianceRecord[] @relation("Verifier")
  approvedExpenses   Expense[]          @relation("ExpenseApprover")

  @@index([email])
}

model Driver {
  id               String       @id @default(uuid())
  fullName         String
  licenseNumber    String       @unique
  licenseExpiry    DateTime
  status           DriverStatus @default(AVAILABLE)
  phone            String       @unique
  complianceVerified Boolean    @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  trips            Trip[]
  complianceDocs   ComplianceRecord[]

  @@index([licenseNumber])
}

model Truck {
  id               String       @id @default(uuid())
  plateNumber      String       @unique
  model            String
  capacityTons     Decimal      @db.Decimal(10, 2)
  type             String       // e.g., Tipper, Flatbed, Tanker, Box Trailer
  status           TruckStatus  @default(AVAILABLE)
  gpsDeviceId      String?      @unique
  complianceVerified Boolean    @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  trips            Trip[]
  complianceDocs   ComplianceRecord[]

  @@index([plateNumber])
  @@index([gpsDeviceId])
}

model ComplianceRecord {
  id             String           @id @default(uuid())
  documentType   DocumentType
  documentNumber String?
  documentUrl    String           // S3 Path
  expiryDate     DateTime
  status         ComplianceStatus @default(PENDING)
  verifiedById   String?
  rejectionReason String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  driverId       String?
  driver         Driver?          @relation(fields: [driverId], references: [id], onDelete: Cascade)
  truckId        String?
  truck          Truck?           @relation(fields: [truckId], references: [id], onDelete: Cascade)
  verifiedBy     User?            @relation("Verifier", fields: [verifiedById], references: [id])

  @@index([driverId])
  @@index([truckId])
  @@index([expiryDate])
}

model Vendor {
  id                 String     @id @default(uuid())
  name               String     @unique
  taxId              String     @unique
  email              String
  phone              String
  address            String
  paymentTermsDays   Int        @default(30)
  isActive           Boolean    @default(true)
  complianceVerified Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  // Relations
  trips              Trip[]
  invoices           Invoice[]

  @@index([taxId])
}

model PurchaseOrder {
  id                  String    @id @default(uuid())
  poNumber            String    @unique
  clientName          String
  commodity           String
  totalQuantityTons   Decimal   @db.Decimal(12, 2)
  allocatedQuantityTons Decimal @db.Decimal(12, 2) @default(0.00)
  ratePerTon          Decimal   @db.Decimal(10, 2)
  currency            String    @default("USD")
  contractUrl         String?
  status              POStatus  @default(DRAFT)
  startDate           DateTime
  endDate             DateTime
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  trips               Trip[]

  @@index([poNumber])
  @@index([clientName])
}

model Trip {
  id                  String         @id @default(uuid())
  tripNumber          String         @unique
  purchaseOrderId     String
  purchaseOrder       PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  driverId            String
  driver              Driver         @relation(fields: [driverId], references: [id])
  truckId             String
  truck               Truck          @relation(fields: [truckId], references: [id])
  vendorId            String?
  vendor              Vendor?        @relation(fields: [vendorId], references: [id])
  
  source              String
  destination         String
  distanceKm          Decimal        @db.Decimal(10, 2)
  estimatedQuantityTons Decimal      @db.Decimal(10, 2)
  actualLoadedTons    Decimal?       @db.Decimal(10, 2)
  actualDeliveredTons Decimal?       @db.Decimal(10, 2)
  
  status              TripStatus     @default(SCHEDULED)
  scheduledStartDate  DateTime
  actualStartDate     DateTime?
  actualEndDate       DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // Relations
  gatepasses          Gatepass[]
  gpsPings            GPSPing[]
  expenses            Expense[]
  invoices            Invoice[]

  @@index([tripNumber])
  @@index([status])
  @@index([purchaseOrderId])
}

model Gatepass {
  id             String         @id @default(uuid())
  gatepassNumber String         @unique
  tripId         String
  trip           Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  type           GatepassType
  status         GatepassStatus @default(ISSUED)
  
  tareWeightTons  Decimal?      @db.Decimal(10, 2)
  grossWeightTons Decimal?      @db.Decimal(10, 2)
  netWeightTons   Decimal?      @db.Decimal(10, 2)
  sealNumber      String?
  remarks         String?
  qrCodeUrl       String?
  
  issuedAt       DateTime       @default(now())
  expiresAt      DateTime
  scannedAt      DateTime?

  @@index([gatepassNumber])
  @@index([tripId])
}

model GPSPing {
  id          String   @id @default(uuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  latitude    Decimal  @db.Decimal(9, 6)
  longitude   Decimal  @db.Decimal(9, 6)
  speedKmh    Decimal  @db.Decimal(5, 2)
  heading     Int
  timestamp   DateTime @default(now())

  @@index([tripId, timestamp(sort: Desc)])
  @@index([timestamp])
}

model Expense {
  id              String          @id @default(uuid())
  tripId          String
  trip            Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  category        ExpenseCategory
  amount          Decimal         @db.Decimal(10, 2)
  currency        String          @default("USD")
  receiptUrl      String?
  description     String?
  status          ExpenseStatus   @default(PENDING)
  approvedById    String?
  approvedBy      User?           @relation("ExpenseApprover", fields: [approvedById], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tripId])
  @@index([status])
}

model Invoice {
  id                 String        @id @default(uuid())
  invoiceNumber      String        @unique
  tripId             String
  trip               Trip          @relation(fields: [tripId], references: [id])
  vendorId           String?
  vendor             Vendor?       @relation(fields: [vendorId], references: [id])
  
  type               InvoiceType
  subtotal           Decimal       @db.Decimal(12, 2)
  taxAmount          Decimal       @db.Decimal(12, 2)
  totalAmount        Decimal       @db.Decimal(12, 2)
  status             InvoiceStatus @default(DRAFT)
  
  dueDate            DateTime
  validatedAt        DateTime?
  reconciledAt       DateTime?
  reconciliationLog  String?       @db.Text
  
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([invoiceNumber])
  @@index([tripId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String
  payload   Json
  ipAddress String?
  timestamp DateTime @default(now())

  @@index([entity, entityId])
  @@index([timestamp])
}
